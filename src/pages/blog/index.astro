---
import Hero from "../../components/hero.astro";
import Layout from "../../layouts/Layout.astro";
import PostCard from "../../components/post-card.astro";
import RevealList from "../../components/reveal-list.astro";
import { postSummaries } from "../../lib/posts";

const posts = postSummaries.filter((post) => !post.isArchived);
---

<Layout
  title="Blog"
  description="Writing about building web apps, product engineering, and the tools I ship."
>
  <section class="space-y-8">
    <Hero
      title="Blog"
      description="Writing about building web apps, product engineering, and the tools I ship."
      goBack={true}
    />

    {
      posts.length > 0 ? (
        <RevealList>
          {posts.map((post, idx) => (
            <li class="reveal" style={`--delay: ${idx * 70}ms`}>
              <PostCard post={post} variant="compact" />
            </li>
          ))}
        </RevealList>
      ) : (
        <p class="text-muted-foreground">
          Still working on it... I'll keep you posted.
        </p>
      )
    }
  </section>
</Layout>
