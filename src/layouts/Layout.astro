---
import { ClientRouter } from "astro:transitions";
import Footer from "../components/footer.astro";
import Header from "../components/header.astro";
import "../styles/global.css";
import { getAvailableLanguages, getTranslations } from "../lib/i18n/server";
import { localeCookieMaxAge, localeCookieName } from "../lib/i18n/request";
import {
  getLocalizedAbsolutePath,
  getLocalizedPath,
  getRoutePathFromUrl,
} from "../lib/i18n/routing";
import type { AppLocale } from "../lib/i18n/request";
import { site } from "../lib/site";

type LayoutProps = {
  description?: string;
  locale: AppLocale;
  ogImage?: string;
  ogType?: string;
  publishedTime?: string;
  title?: string;
  twitterImage?: string;
};

const {
  description,
  locale,
  ogImage,
  ogType = "website",
  publishedTime,
  title,
  twitterImage,
} = Astro.props as LayoutProps;

const t = await getTranslations();
const languages = await getAvailableLanguages();

const siteName = site.siteName;
const siteUrl = site.siteUrl;
const defaultTitle = t("meta.defaultTitle");
const defaultDescription = t("meta.defaultDescription");
const fullTitle = title ? `${title} | ${siteName}` : defaultTitle;
const metaDescription = description ?? defaultDescription;
const resolvedOgImage = ogImage ?? `${siteUrl}/og-image.png`;
const resolvedTwitterImage = twitterImage ?? resolvedOgImage;
const currentRoutePath = getRoutePathFromUrl(Astro.url.pathname);
const canonicalUrl = getLocalizedAbsolutePath(locale, currentRoutePath);

const navItems = [
  {
    href: getLocalizedPath(locale, "/projects"),
    label: t("header.projects"),
  },
  {
    href: getLocalizedPath(locale, "/blog"),
    label: t("header.blog"),
  },
];

const localeSwitchItems = languages.map((language) => {
  const languageLocale = language.locale as AppLocale;

  return {
    locale: languageLocale,
    isCurrent: languageLocale === locale,
    label: language.shortLabel ?? language.nativeLabel,
    nativeLabel: language.nativeLabel,
  };
});

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: site.author,
  jobTitle: site.jobTitle,
  sameAs: site.sameAs,
  url: siteUrl,
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  description: defaultDescription,
  name: siteName,
  publisher: {
    "@type": "Person",
    name: site.author,
    url: siteUrl,
  },
  url: siteUrl,
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <ClientRouter fallback="swap" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content={site.author} />
    <meta name="robots" content="index,follow" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />

    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="760" />
    <meta property="og:image:height" content="397" />
    <meta property="og:image:alt" content={fullTitle} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={site.twitterHandle} />
    <meta name="twitter:creator" content={site.twitterHandle} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={resolvedTwitterImage} />
    <meta name="twitter:image:alt" content={fullTitle} />
    {publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    <script type="application/ld+json">
      {JSON.stringify(personJsonLd)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(websiteJsonLd)}
    </script>

    <slot name="head" />

    <script is:inline>
      (function () {
        const win = window;

        function getTheme() {
          const storedTheme = localStorage.getItem("theme");

          if (storedTheme === "light" || storedTheme === "dark") {
            return storedTheme;
          }

          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        function applyTheme(theme, root = document.documentElement) {
          if (!root) {
            return;
          }

          root.classList.toggle("dark", theme === "dark");
          root.dataset.theme = theme;
        }

        win.__r1goGetTheme = getTheme;
        win.__r1goApplyTheme = applyTheme;

        applyTheme(getTheme());

        if (!win.__r1goThemeSyncSetup) {
          win.__r1goThemeSyncSetup = true;

          document.addEventListener("astro:before-swap", (event) => {
            applyTheme(getTheme(), event.newDocument.documentElement);
          });

          document.addEventListener("astro:after-swap", () => {
            applyTheme(getTheme());
          });
        }
      })();
    </script>

    <script is:inline>
      (function () {
        const win = window;
        const skipRevealStorageKey = "r1go_skip_reveal";

        function cleanupRevealObservers() {
          (win.__r1goRevealObservers || []).forEach((observer) =>
            observer.disconnect(),
          );
          win.__r1goRevealObservers = [];
        }

        function showRevealItems(items) {
          items.forEach((item) => item.classList.add("is-visible"));
        }

        function shouldSkipRevealAnimation() {
          if (win.__r1goSoftNavigated) {
            return true;
          }

          try {
            if (sessionStorage.getItem(skipRevealStorageKey) === "1") {
              sessionStorage.removeItem(skipRevealStorageKey);
              return true;
            }
          } catch {}

          const navigationEntry = performance.getEntriesByType("navigation")[0];

          return navigationEntry?.type === "reload";
        }

        function initRevealItems() {
          const items = document.querySelectorAll(".reveal");

          cleanupRevealObservers();

          if (items.length === 0) {
            return;
          }

          const reduceMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
          ).matches;

          if (reduceMotion || shouldSkipRevealAnimation()) {
            showRevealItems(items);
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  observer.unobserve(entry.target);
                }
              }
            },
            { threshold: 0.15 },
          );

          items.forEach((item) => observer.observe(item));
          win.__r1goRevealObservers = [observer];
        }

        if (!win.__r1goRevealSetup) {
          win.__r1goRevealSetup = true;
          win.__r1goRevealObservers = [];
          win.__r1goSoftNavigated = false;

          document.addEventListener("astro:before-preparation", () => {
            win.__r1goSoftNavigated = true;
            cleanupRevealObservers();
          });

          document.addEventListener("astro:page-load", initRevealItems);
        }

        initRevealItems();
      })();
    </script>
  </head>
  <body class={`font-sans antialiased`}>
    <Header
      homeHref={getLocalizedPath(locale, "/")}
      homeLabel={t("header.homeLabel")}
      localeCookieMaxAge={localeCookieMaxAge}
      localeCookieName={localeCookieName}
      languageSwitcherLabel={t("header.languageSwitcher")}
      localeSwitchItems={localeSwitchItems}
      navItems={navItems}
      themeToggleLabel={t("header.toggleTheme")}
    />
    <main class="mx-auto max-w-2xl px-6 mt-24 mb-12">
      <slot />
    </main>
    <Footer text={t("footer.copyright")} />
  </body>
</html>
